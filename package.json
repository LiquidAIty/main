{
  "name": "main",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "npm run dev:fresh",
    "dev:fresh": "tsx scripts/dev-fresh.ts",
    "dev:frontend": "npm --workspace client run dev",
    "dev:backend": "npm --workspace apps/backend run serve",
    "dev:autogen": "tsx scripts/uvicorn-guard.ts autogen",
    "dev:knowgraph": "tsx scripts/uvicorn-guard.ts knowgraph",
    "dev:grpc": "tsx scripts/grpc-guard.ts",
    "dev:mcp": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-http-mcp.ps1",
    "dev:all": "concurrently --names autogen,backend,grpc,frontend,knowgraph,mcp --prefix-colors cyan,magenta,yellow,green,blue,white \"npm run dev:autogen\" \"npm run dev:backend\" \"npm run dev:grpc\" \"npm run dev:frontend\" \"npm run dev:knowgraph\" \"npm run dev:mcp\"",
    "mcp:check": "powershell -ExecutionPolicy Bypass -File scripts/check-codebase-memory-mcp.ps1",
    "typecheck": "npm run typecheck --workspace client && npm run typecheck --workspace apps/backend",
    "typecheck:spec": "npm run typecheck:spec --workspace client && npm run typecheck:spec --workspace apps/backend",
    "typecheck:all": "npm run typecheck && npm run typecheck:spec",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma --name init",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "test": "vitest run"
  },
  "private": true,
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "axios": "^1.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "troika-three-text": "^0.52.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nx/esbuild": "21.3.0",
    "@nx/eslint-plugin": "21.3.0",
    "@nx/js": "^21.3.0",
    "@nx/react": "21.3.0",
    "@nx/vite": "21.3.0",
    "@playwright/test": "^1.59.1",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.1.0",
    "@types/node": "^20.19.22",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "21.3.0",
    "postcss": "^8.5.6",
    "prettier": "^2.6.2",
    "prisma": "^6.14.0",
    "tailwindcss": "^4.1.12",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.20.6",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.3.5",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "client"
  ],
  "type": "module",
  "description": "# LiquidAIty \u2014 Agentic AI Core",
  "directories": {
    "doc": "docs"
  },
  "keywords": [],
  "author": ""
}
