{
  "mcpServers": {
    "filesystem": {
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "./"],
      "restart": { "enabled": true, "maxAttempts": 3, "delayMs": 1000 }
    },
    "codebase-memory": {
      "transport": "stdio",
      "command": "C:\\cbm\\codebase-memory-mcp.exe",
      "restart": { "enabled": true, "maxAttempts": 3, "delayMs": 1000 }
    },
    "github": {
      "transport": "sse",
      "url": "${GITHUB_MCP_URL}",
      "headers": { "Authorization": "Bearer ${GITHUB_TOKEN}" }
    },
    "supabase": {
      "transport": "sse",
      "url": "${SUPABASE_MCP_URL}",
      "headers": {
        "apikey": "${SUPABASE_SERVICE_KEY}",
        "Authorization": "Bearer ${SUPABASE_SERVICE_KEY}"
      }
    },
    "tavily": {
      "transport": "http",
      "url": "${TAVILY_MCP_URL}",
      "headers": {
        "Authorization": "Bearer ${TAVILY_API_KEY}",
        "DEFAULT_PARAMETERS": "${TAVILY_MCP_DEFAULT_PARAMETERS}"
      }
    }
  }
}
